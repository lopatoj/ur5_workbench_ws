			<origin rpy="0 1.570796326794897 0" xyz="-0.2125 0.0 0.11336"/>
			<inertia ixx="0.13388583541666665" ixy="0" ixz="0" iyy="0.13388583541666665" iyz="0" izz="0.0151074"/>
		</inertial>
	</link>
	<link name="thing2_forearm_link">
