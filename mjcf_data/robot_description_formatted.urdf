		</inertial>
	</link>
	<!-- base_joint fixes base_link to the environment -->
	<joint name="thing2_base_joint" type="fixed">
		<origin rpy="0 0 1.5707963267948966" xyz="0.381 0.381 0"/>
		<parent link="table"/>
		<child link="thing2_base_link"/>
	</joint>
	<!-- joints - main serial chain -->
	<joint name="thing2_base_link-base_link_inertia" type="fixed">
		<parent link="thing2_base_link"/>
		<child link="thing2_base_link_inertia"/>
		<!-- 'base_link' is REP-103 aligned (so X+ forward), while the internal
           frames of the robot/controller have X+ pointing backwards.
           Use the joint between 'base_link' and 'base_link_inertia' (a dummy
           link/frame) to introduce the necessary rotation over Z (of pi rad).
      -->
		<origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
	</joint>
	<joint name="thing2_shoulder_pan_joint" type="revolute">
		<parent link="thing2_base_link_inertia"/>
		<child link="thing2_shoulder_link"/>
		<origin rpy="0 0 0" xyz="0 0 0.089159"/>
		<axis xyz="0 0 1"/>
		<limit effort="150.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
		<dynamics damping="0" friction="0"/>
	</joint>
	<joint name="thing2_shoulder_lift_joint" type="revolute">
		<parent link="thing2_shoulder_link"/>
		<child link="thing2_upper_arm_link"/>
		<origin rpy="1.570796327 0 0" xyz="0 0 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="150.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
		<dynamics damping="0" friction="0"/>
	</joint>
	<joint name="thing2_elbow_joint" type="revolute">
		<parent link="thing2_upper_arm_link"/>
		<child link="thing2_forearm_link"/>
		<origin rpy="0 0 0" xyz="-0.425 0 0"/>
		<axis xyz="0 0 1"/>
		<limit effort="150.0" lower="-3.141592653589793" upper="3.141592653589793" velocity="3.141592653589793"/>
		<dynamics damping="0" friction="0"/>
	</joint>
	<joint name="thing2_wrist_1_joint" type="revolute">
		<parent link="thing2_forearm_link"/>
		<child link="thing2_wrist_1_link"/>
		<origin rpy="0 0 0" xyz="-0.39225 0 0.10915"/>
		<axis xyz="0 0 1"/>
		<limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
		<dynamics damping="0" friction="0"/>
	</joint>
	<joint name="thing2_wrist_2_joint" type="revolute">
		<parent link="thing2_wrist_1_link"/>
		<child link="thing2_wrist_2_link"/>
		<origin rpy="1.570796327 0 0" xyz="0 -0.09465 -1.941303950897609e-11"/>
		<axis xyz="0 0 1"/>
		<limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
		<dynamics damping="0" friction="0"/>
	</joint>
	<joint name="thing2_wrist_3_joint" type="revolute">
		<parent link="thing2_wrist_2_link"/>
		<child link="thing2_wrist_3_link"/>
		<origin rpy="1.570796326589793 3.141592653589793 3.141592653589793" xyz="0 0.0823 -1.688001216681175e-11"/>
		<axis xyz="0 0 1"/>
		<limit effort="28.0" lower="-6.283185307179586" upper="6.283185307179586" velocity="3.141592653589793"/>
		<dynamics damping="0" friction="0"/>
	</joint>
	<link name="thing2_ft_frame"/>
	<joint name="thing2_wrist_3_link-ft_frame" type="fixed">
		<parent link="thing2_wrist_3_link"/>
		<child link="thing2_ft_frame"/>
		<origin rpy="3.141592653589793 0 0" xyz="0 0 0"/>
	</joint>
	<!-- ROS-Industrial 'base' frame - base_link to UR 'Base' Coordinates transform -->
	<link name="thing2_base"/>
	<joint name="thing2_base_link-base_fixed_joint" type="fixed">
		<!-- Note the rotation over Z of pi radians - as base_link is REP-103
           aligned (i.e., has X+ forward, Y+ left and Z+ up), this is needed
           to correctly align 'base' with the 'Base' coordinate system of
           the UR controller.
      -->
		<origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
		<parent link="thing2_base_link"/>
		<child link="thing2_base"/>
	</joint>
	<!-- ROS-Industrial 'flange' frame - attachment point for EEF models -->
	<link name="thing2_flange"/>
	<joint name="thing2_wrist_3-flange" type="fixed">
		<parent link="thing2_wrist_3_link"/>
		<child link="thing2_flange"/>
		<origin rpy="0 -1.5707963267948966 -1.5707963267948966" xyz="0 0 0"/>
	</joint>
	<!-- ROS-Industrial 'tool0' frame - all-zeros tool frame -->
	<link name="thing2_tool0"/>
	<joint name="thing2_flange-tool0" type="fixed">
		<!-- default toolframe - X+ left, Y+ up, Z+ front -->
		<origin rpy="1.5707963267948966 0 1.5707963267948966" xyz="0 0 0"/>
		<parent link="thing2_flange"/>
		<child link="thing2_tool0"/>
	</joint>
