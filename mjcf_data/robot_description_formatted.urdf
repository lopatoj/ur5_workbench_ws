		</inertial>
	</link>
	<link name="thing2_wrist_1_link">
		<visual>
			<origin rpy="1.5707963267948966 0 0" xyz="0 0 -0.093"/>
			<geometry>
				<mesh filename="full/wrist1.obj"/>
			</geometry>
